{
  "name": "bm25s",
  "version": "1.0.0",
  "description": "Ultra-fast BM25 full-text search for JavaScript. Zero dependencies, multi-runtime (Node.js, Bun, Deno). Eager sparse scoring with CSC matrices.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js --platform=node",
    "build:cjs": "esbuild src/index.ts --bundle --format=cjs --outfile=dist/index.cjs --platform=node",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:node": "node --test tests/*.test.js",
    "test:bun": "bun test",
    "benchmark": "bun run benchmarks/benchmark.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bm25",
    "bm25s",
    "search",
    "full-text-search",
    "information-retrieval",
    "text-search",
    "lexical-search",
    "sparse-retrieval",
    "document-retrieval",
    "ranking",
    "nodejs",
    "bun",
    "deno",
    "typescript",
    "zero-dependencies",
    "fast",
    "performant",
    "multi-runtime"
  ],
  "author": "Antonio Oliveira <antonio@oakoliver.com> (https://oakoliver.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oakoliver/bm25s.git"
  },
  "homepage": "https://github.com/oakoliver/bm25s#readme",
  "bugs": {
    "url": "https://github.com/oakoliver/bm25s/issues"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
